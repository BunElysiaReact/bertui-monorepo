{
  "name": "bertui",
  "version": "2.0.1",
  "description": "Zero-config React framework powered by Bun — minimal core, optional everything else",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "bertui": "./bin/bertui.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./router": {
      "import": "./dist/router.js",
      "types": "./dist/router.d.ts"
    },
    "./config": {
      "import": "./dist/config.js",
      "types": "./dist/config.d.ts"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --format esm && tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bertui/core": "^1.0.0",
    "@bertui/compiler": "^1.0.0",
    "@bertui/router": "^1.0.0",
    "@bertui/ssg": "^1.0.0",
    "@bertui/css": "^1.0.0",
    "@bertui/cli": "^1.0.0",
    "@bertui/dev": "^1.0.0",
    "@bertui/images": "^1.0.0"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "devDependencies": {
    "typescript": "^6.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  },
  "keywords": ["react", "bun", "ssr", "ssg", "file-based-routing", "islands", "zero-config"],
  "author": "Pease Ernest",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BunElysiaReact/BERTUI"
  }
}