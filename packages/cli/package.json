{
  "name": "@bertui/cli",
  "version": "1.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --format esm --external lightningcss --external @bertui/css",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "lightningcss": "latest",
    "@bertui/core": "^1.0.0",
    "@bertui/compiler": "^1.0.0",
    "@bertui/dev": "^1.0.0",
    "@bertui/css": "^1.0.0",
    "@bertui/images": "^1.0.0",
    "@bertui/ssg": "^1.0.0"
  },
  "devDependencies": {
    "typescript": "^6.0.0"
  }
}