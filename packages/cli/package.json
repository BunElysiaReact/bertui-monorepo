{
  "name": "@bertui/cli",
  "version": "2.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --format esm --external lightningcss --external @bertui/css",
    "typecheck": "tsc --noEmit"
  },
 
  "dependencies": {
    "lightningcss": "latest",
    "@bertui/core": "workspace:*",
    "@bertui/compiler": "workspace:*",
    "@bertui/dev": "workspace:*",
    "@bertui/css": "workspace:*",
    "@bertui/images": "workspace:*",
    "@bertui/ssg": "workspace:*"
    

  },
  "devDependencies": {
    "typescript": "^6.0.0"
  }
}
